# Claude / Anthropic API key — required for AI summarization.
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY="your-anthropic-api-key"

# The URL where this app is hosted (used for self-referential links).
APP_URL="http://localhost:3000"

# --- Firebase configuration ---
# Leave these blank to use the values from firebase-applet-config.json.
# Set them to point to your own Firebase project.
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
# Firestore named database ID. Use "(default)" for a standard Firebase project.
# AI Studio projects use a custom ID like "ai-studio-xxxx".
VITE_FIREBASE_DATABASE_ID=""
