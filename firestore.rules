rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidSummary(data) {
      return data.keys().hasAll(['id', 'userId', 'title'])
          && data.id is string
          && data.userId is string
          && data.title is string
          && data.userId == request.auth.uid;
    }

    match /users/{userId}/summaries/{summaryId} {
      allow read, list: if isSignedIn() && request.auth.uid == userId;
      
      allow create: if isSignedIn()
                    && isValidId(userId)
                    && isValidId(summaryId)
                    && request.auth.uid == userId
                    && isValidSummary(incoming());

      allow update: if isSignedIn()
                    && isValidId(userId)
                    && isValidId(summaryId)
                    && request.auth.uid == userId
                    && isValidSummary(incoming())
                    && incoming().userId == existing().userId;

      allow delete: if isSignedIn()
                    && request.auth.uid == userId;
    }
  }
}
